{
  "type": "module",
  "name": "ft-transcendence",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:client": "npm run dev --workspace=frontend",
    "dev:server": "npm run dev --workspace=server",
    "build:client": "npm run build --workspace=frontend",
    "build:server": "npm run build --workspace=server",
    "start:all": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "test": "jest --config tests/jest.config.js",
    "test:watch": "jest --config tests/jest.config.js --watch",
    "test:coverage": "jest --config tests/jest.config.js --coverage",
    "test:verbose": "jest --config tests/jest.config.js --verbose",
    "test:ci": "jest --config tests/jest.config.js --ci --coverage --forceExit",
    "test:all": "./tools/test-runner.sh",
    "test:tournament": "npx ts-node tools/test-tournament.ts",
    "test:tournament:4": "npx ts-node tools/test-tournament.ts --players=4 --run",
    "test:tournament:8": "npx ts-node tools/test-tournament.ts --players=8 --run"
  },
  "devDependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "fastify": "^4.29.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
